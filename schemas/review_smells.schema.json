{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TiDB Flaky Review Smells",
  "type": "object",
  "required": ["schema_version", "smells"],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "smells": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "title",
          "description",
          "why_risky",
          "review_questions",
          "suggested_fixes",
          "related_root_causes",
          "status"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "why_risky": {
            "type": "string",
            "minLength": 1
          },
          "review_questions": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "suggested_fixes": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "related_root_causes": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"}
          },
          "applies_to": {
            "type": "array",
            "items": {"type": "string", "enum": ["unit", "integration", "realtikv"]}
          },
          "severity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "examples": {
            "type": ["string", "object", "array", "null"]
          },
          "references": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated"]
          },
          "replaced_by": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "aliases": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

