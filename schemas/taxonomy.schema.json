{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TiDB Flaky Root Cause Taxonomy",
  "type": "object",
  "required": ["schema_version", "categories"],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "name", "definition", "status"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated"]
          },
          "symptoms": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "common_triggers": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "fix_patterns": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "related_smells": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"}
          },
          "references": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "replaced_by": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "aliases": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

